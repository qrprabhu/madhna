{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(tasklist //FI \"IMAGENAME eq node.exe\" //FO CSV)",
      "Bash(sleep 2; tail -n 15 /tmp/dev.log)",
      "Read(//tmp/**)",
      "Bash(curl -s -o /dev/null -w \"3000:%{http_code} \" http://localhost:3000/submit-petition --max-time 5)",
      "Bash(curl -s -o /dev/null -w \"3001:%{http_code}\\\\n\" http://localhost:3001/submit-petition --max-time 5)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" http://localhost:3000/submit-petition --max-time 5)",
      "Bash(curl -s -o /dev/null -w \"home:%{http_code} submit:\" http://localhost:3000/ --max-time 5)",
      "Bash(curl -s -o /dev/null -w \"submit:%{http_code} \" http://localhost:3000/submit-petition --max-time 5)",
      "Bash(curl -s -o /dev/null -w \"admin:%{http_code}\\\\n\" http://localhost:3000/admin --max-time 5)",
      "Bash(curl -s -o /dev/null -w \"submit:%{http_code}\\\\n\" http://localhost:3000/submit-petition --max-time 5)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
